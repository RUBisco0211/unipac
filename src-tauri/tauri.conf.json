{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "unipac",
  "version": "0.1.0",
  "identifier": "com.rubisco.unipac",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
          "title": "unipac",
          "width": 1200,
          "height": 800,
          "minWidth": 800,
          "minHeight": 600,
          "titleBarStyle": "Transparent",
          "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
